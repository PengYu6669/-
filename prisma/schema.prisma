generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── 项目/批次 ───
model Project {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @db.VarChar(255)
  status    String   @default("pending") @db.VarChar(20) // pending|processing|completed|failed
  fileCount Int      @default(0) @map("file_count")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  files    File[]
  invoices Invoice[]
  receipts Receipt[]
  links    InvoiceReceiptLink[]
  audits   AuditLog[]
  templates Template[]

  @@map("projects")
}

// ─── 原始文件 ───
model File {
  id           String   @id @default(uuid()) @db.Uuid
  projectId    String   @map("project_id") @db.Uuid
  originalName String   @map("original_name") @db.VarChar(500)
  storedPath   String   @map("stored_path") @db.VarChar(1000)
  fileType     String   @map("file_type") @db.VarChar(10) // pdf|jpg|png
  fileSize     BigInt?  @map("file_size")
  category     String?  @db.VarChar(20) // invoice|receipt|unknown
  parentDir    String?  @map("parent_dir") @db.VarChar(500)
  pageCount    Int      @default(1) @map("page_count")
  hashSha256   String?  @map("hash_sha256") @db.VarChar(64)
  createdAt    DateTime @default(now()) @map("created_at")

  project  Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  invoices Invoice[]
  receipts Receipt[]
  audits   AuditLog[]

  @@map("files")
}

// ─── 发票提取结果 ───
model Invoice {
  id            String   @id @default(uuid()) @db.Uuid
  projectId     String   @map("project_id") @db.Uuid
  fileId        String   @map("file_id") @db.Uuid
  invoiceNo     String?  @map("invoice_no") @db.VarChar(50)
  invoiceCode   String?  @map("invoice_code") @db.VarChar(50)
  amountExclTax Decimal? @map("amount_excl_tax") @db.Decimal(15, 2)
  taxAmount     Decimal? @map("tax_amount") @db.Decimal(15, 2)
  amountInclTax Decimal? @map("amount_incl_tax") @db.Decimal(15, 2)
  invoiceDate   DateTime? @map("invoice_date") @db.Date
  sellerName    String?  @map("seller_name") @db.VarChar(300)
  buyerName     String?  @map("buyer_name") @db.VarChar(300)
  orderNo       String?  @map("order_no") @db.VarChar(100)
  rawOcrJson    Json?    @map("raw_ocr_json")
  rawLlmJson    Json?    @map("raw_llm_json")
  confidence    Decimal? @map("confidence") @db.Decimal(3, 2)
  status        String   @default("pending") @db.VarChar(20)
  createdAt     DateTime @default(now()) @map("created_at")

  project Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  file    File                @relation(fields: [fileId], references: [id])
  links   InvoiceReceiptLink[]

  @@map("invoices")
}

// ─── 签收单提取结果 ───
model Receipt {
  id           String   @id @default(uuid()) @db.Uuid
  projectId    String   @map("project_id") @db.Uuid
  fileId       String   @map("file_id") @db.Uuid
  documentCode String?  @map("document_code") @db.VarChar(100)
  orderNo      String?  @map("order_no") @db.VarChar(100)
  receiptDate  DateTime? @map("receipt_date") @db.Date
  amount       Decimal? @map("amount") @db.Decimal(15, 2)
  recipient    String?  @db.VarChar(100)
  rawOcrText   String?  @map("raw_ocr_text") @db.Text
  rawLlmJson   Json?    @map("raw_llm_json")
  confidence   Decimal? @map("confidence") @db.Decimal(3, 2)
  status       String   @default("pending") @db.VarChar(20)
  createdAt    DateTime @default(now()) @map("created_at")

  project Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  file    File                @relation(fields: [fileId], references: [id])
  links   InvoiceReceiptLink[]

  @@map("receipts")
}

// ─── 发票-签收单关联 ───
model InvoiceReceiptLink {
  id        String   @id @default(uuid()) @db.Uuid
  projectId String   @map("project_id") @db.Uuid
  invoiceId String   @map("invoice_id") @db.Uuid
  receiptId String   @map("receipt_id") @db.Uuid
  matchType String   @default("auto") @map("match_type") @db.VarChar(20) // auto|manual
  matchKey  String?  @map("match_key") @db.VarChar(200)
  createdAt DateTime @default(now()) @map("created_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  invoice Invoice @relation(fields: [invoiceId], references: [id])
  receipt Receipt @relation(fields: [receiptId], references: [id])

  @@map("invoice_receipt_links")
}

// ─── 审计日志 ───
model AuditLog {
  id           String   @id @default(uuid()) @db.Uuid
  projectId    String   @map("project_id") @db.Uuid
  fileId       String?  @map("file_id") @db.Uuid
  step         String   @db.VarChar(50) // upload|pdf_convert|ocr|llm_extract|match|export|manual_edit
  action       String?  @db.VarChar(200)
  inputData    Json?    @map("input_data")
  outputData   Json?    @map("output_data")
  status       String?  @db.VarChar(20) // success|failed|warning
  errorMessage String?  @map("error_message") @db.Text
  durationMs   Int?     @map("duration_ms")
  createdAt    DateTime @default(now()) @map("created_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  file    File?   @relation(fields: [fileId], references: [id])

  @@map("audit_logs")
}

// ─── Excel模板 ───
model Template {
  id           String   @id @default(uuid()) @db.Uuid
  projectId    String   @map("project_id") @db.Uuid
  originalName String   @map("original_name") @db.VarChar(500)
  storedPath   String   @map("stored_path") @db.VarChar(1000)
  headers      Json     @default("[]") // ["发票号码", "不含税金额", ...]
  createdAt    DateTime @default(now()) @map("created_at")

  project Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  mappings FieldMapping[]

  @@map("templates")
}

// ─── 字段映射 ───
model FieldMapping {
  id           String   @id @default(uuid()) @db.Uuid
  templateId   String   @map("template_id") @db.Uuid
  columnIndex  Int      @map("column_index")
  headerName   String   @map("header_name") @db.VarChar(200)
  sourceType   String?  @map("source_type") @db.VarChar(20) // invoice|receipt|static
  sourceField  String?  @map("source_field") @db.VarChar(100) // invoiceNo, amountExclTax, documentCode, etc.
  suggestedBy  String   @default("ai") @map("suggested_by") @db.VarChar(20) // ai|user
  staticValue  String?  @map("static_value") @db.VarChar(500) // 固定值
  createdAt    DateTime @default(now()) @map("created_at")

  template Template @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@map("field_mappings")
}
